generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tasks       Task[]
  lists       List[]
  tags        Tag[]
  stickyNotes StickyNote[]
}

model Task {
  id          String    @id @default(cuid())
  title       String
  completed   Boolean   @default(false)
  dueDate     DateTime?
  timeGroup   String    @default("today") // today, tomorrow, this_week
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  listId String?
  list   List?   @relation(fields: [listId], references: [id], onDelete: SetNull)

  subtasks Subtask[]
  tags     Tag[]     @relation("TaskTags")

  @@index([userId])
  @@index([userId, dueDate])
}

model Subtask {
  id        String  @id @default(cuid())
  title     String
  completed Boolean @default(false)

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

model List {
  id    String @id @default(cuid())
  name  String
  color String @default("#C74B4B")

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tasks Task[]

  @@index([userId])
}

model Tag {
  id    String @id @default(cuid())
  name  String
  color String @default("#E8E8E8")

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tasks Task[] @relation("TaskTags")

  @@index([userId])
}

model StickyNote {
  id      String @id @default(cuid())
  title   String
  content String @default("")
  color   String @default("yellow") // yellow, cyan, pink, orange

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
